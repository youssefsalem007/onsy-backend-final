{
  "name": "onsy",
  "version": "1.0.0",
  "description": "",
  "main": "./src/index.js",
  "scripts": {
    "dev": "concurrently --names \"BACKEND,AI\" --prefix-colors \"cyan,magenta\" \"npm run dev:backend\" \"npm run dev:ai\"",
    "dev:backend": "cross-env NODE_ENV=development nodemon src/index.js",
    "dev:ai": "cd ai_engine && IF EXIST venv\\Scripts\\python.exe (venv\\Scripts\\python.exe main.py) ELSE (python main.py)",
    "start": "cross-env NODE_ENV=production node src/index.js",
    "start:ai": "cd ai_engine && IF EXIST venv\\Scripts\\python.exe (venv\\Scripts\\python.exe -m uvicorn main:app --host 0.0.0.0 --port 8000 --workers 2) ELSE (python -m uvicorn main:app --host 0.0.0.0 --port 8000 --workers 2)",
    "start:all": "concurrently --names \"BACKEND,AI\" --prefix-colors \"cyan,magenta\" \"npm run start\" \"npm run start:ai\"",
    "install:all": "npm install"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "module",
  "dependencies": {
    "axios": "^1.16.1",
    "bcrypt": "^6.0.0",
    "cloudinary": "^2.9.0",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "cross-env": "^10.1.0",
    "csv-parse": "^6.2.1",
    "dotenv": "^17.3.1",
    "express": "^5.2.1",
    "google-auth-library": "^10.6.2",
    "joi": "^18.0.2",
    "jsonwebtoken": "^9.0.3",
    "mongoose": "^9.2.4",
    "multer": "^2.1.1",
    "nodemailer": "^8.0.2",
    "nodemon": "^3.1.14",
    "redis": "^5.11.0",
    "socket.io": "^4.8.3",
    "uuid": "^13.0.2"
  }
}
